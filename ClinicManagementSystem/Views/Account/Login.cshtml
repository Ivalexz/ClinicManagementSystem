@{
    ViewData["Title"] = "Вхід";
}

<div class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">

                <div class="auth-card">
                    <div class="auth-logo mb-4">
                        <div class="logo-icon mx-auto mb-3">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                        <h1 class="auth-title">Вхід до PawCare</h1>
                        <p class="auth-sub">Введіть свої дані для входу</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="auth-alert mb-3">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-envelope input-icon"></i>
                                <input type="email" name="email" class="form-control ps-input-icon"
                                       placeholder="your@email.com" required autocomplete="email"/>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Пароль</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" name="password" class="form-control ps-input-icon"
                                       placeholder="••••••••" required autocomplete="current-password"/>
                            </div>
                        </div>

                        <button type="submit" class="btn-submit">
                            Увійти <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <p class="auth-footer-text mt-4">
                        Ще немає акаунту?
                        <a asp-controller="Account" asp-action="Register" class="auth-link">Зареєструватися</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>
