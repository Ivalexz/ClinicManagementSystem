@{
    ViewData["Title"] = "Register";
}

<div class="login-wrapper d-flex justify-content-center align-items-center">
    <div class="login-card shadow-lg p-4">

        <h2 class="text-center mb-4 fw-bold text-primary">Реєстрація</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form asp-action="Register" method="post" class="mt-3">

            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" name="email" class="form-control form-control-lg" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Пароль</label>
                <input type="password" name="password" class="form-control form-control-lg" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg mt-3">
                Зареєструватися
            </button>
        </form>

        <p class="text-center mt-3">
            Вже маєте акаунт?
            <a asp-action="Login" class="text-primary fw-semibold">Увійти</a>
        </p>
    </div>
</div>