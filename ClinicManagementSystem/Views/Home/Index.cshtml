@{
    ViewData["Title"] = "Головна";
}

<div class="hero text-center mb-5">
    <h1 class="display-4 fw-bold">Clinic Management System</h1>
    <p class="lead">Сучасна система керування клінікою для лікарів, пацієнтів та адміністраторів.</p>
    <a href="/Appointments" class="btn btn-light btn-lg mt-3 px-4">Записатися на прийом</a>
</div>

<h2 class="fw-bold mb-4 text-center">Наші сервіси</h2>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card p-4 text-center shadow-sm">
            <i class="bi bi-person-lines-fill fs-1 text-primary"></i>
            <h4 class="mt-3">Пацієнти</h4>
            <p>Керування інформацією про пацієнтів.</p>
            <a href="/Patients" class="btn btn-outline-primary">Перейти</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-4 text-center shadow-sm">
            <i class="bi bi-heart-pulse fs-1 text-primary"></i>
            <h4 class="mt-3">Лікарі</h4>
            <p>Перегляд лікарів та їх спеціалізацій.</p>
            <a href="/Doctors" class="btn btn-outline-primary">Перейти</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-4 text-center shadow-sm">
            <i class="bi bi-calendar-check fs-1 text-primary"></i>
            <h4 class="mt-3">Записи</h4>
            <p>Керування записами на прийом.</p>
            <a href="/Appointments" class="btn btn-outline-primary">Перейти</a>
        </div>
    </div>
</div>