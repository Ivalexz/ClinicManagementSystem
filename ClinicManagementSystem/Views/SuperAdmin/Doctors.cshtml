@model IEnumerable<ApplicationUser>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Доктори</h2>

    <a href="/SuperAdmin/CreateDoctor" class="btn btn-success">
        <i class="bi bi-person-plus-fill"></i> Створити доктора
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover table-striped mb-0">
            <thead class="table-primary">
            <tr>
                <th>Ім'я</th>
                <th>Прізвище</th>
                <th>Email</th>
                <th class="text-center" style="width: 200px;">Дії</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FirstName</td>
                    <td>@user.LastName</td>
                    <td>@user.Email</td>

                    <td class="text-center">

                        <a href="/SuperAdmin/Edit/@user.Id"
                           class="btn btn-outline-warning btn-sm me-1">
                            <i class="bi bi-pencil-square"></i> Редагувати
                        </a>

                        <a href="/SuperAdmin/Delete/@user.Id"
                           class="btn btn-outline-danger btn-sm"
                           onclick="return confirm('Видалити доктора?')">
                            <i class="bi bi-trash"></i> Видалити
                        </a>

                    </td>
                </tr>
            }
            </tbody>
        </table>

    </div>
</div>