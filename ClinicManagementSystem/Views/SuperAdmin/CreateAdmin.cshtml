@model ApplicationUser

@{
    ViewData["Title"] = "Створення Адміна";
}

<style>
    :root{--green-900:#0f3d2a;--green-700:#198754;--green-100:#f0faf5;--text-main:#111827;--text-muted:#6b7280;--border:#e5e7eb;--radius-lg:20px;--radius-sm:10px;--shadow-md:0 8px 32px rgba(0,0,0,.09)}
    .pw-page{padding:2.5rem 0 3rem}
    .pw-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;gap:1rem;flex-wrap:wrap}
    .pw-title{font-family:'Fraunces',serif;font-size:1.9rem;font-weight:700;color:var(--text-main);margin:0}
    .pw-card{background:#fff;border-radius:var(--radius-lg);box-shadow:var(--shadow-md);border:1.5px solid var(--border);overflow:hidden}
    .pw-btn-back{font-family:'DM Sans',sans-serif;font-size:.875rem;font-weight:500;color:var(--text-muted);background:#fff;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:.5rem 1.1rem;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;transition:border-color .2s,color .2s}
    .pw-btn-back:hover{border-color:var(--green-700);color:var(--green-700)}

    .pw-form-body{padding:2.2rem 2.4rem}
    .pw-label{font-family:'DM Sans',sans-serif;font-size:.75rem;font-weight:600;color:var(--text-muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:.4rem;display:block}
    .pw-input{font-family:'DM Sans',sans-serif;font-size:.95rem;color:var(--text-main);background:#fafafa;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:.65rem 1rem;width:100%;transition:border-color .2s,box-shadow .2s,background .2s}
    .pw-input:focus{outline:none;border-color:var(--green-700);box-shadow:0 0 0 3px rgba(25,135,84,.11);background:#fff}
    .pw-form-footer{padding:1.3rem 2.4rem 2rem;border-top:1.5px solid var(--green-100);background:var(--green-100);display:flex;align-items:center;gap:1rem}
    .pw-btn-submit{font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:500;color:#fff;background:linear-gradient(135deg,#2563eb,#1d4ed8);border:none;border-radius:var(--radius-sm);padding:.65rem 1.5rem;display:inline-flex;align-items:center;gap:.45rem;box-shadow:0 4px 14px rgba(37,99,235,.25);transition:filter .2s,transform .15s;cursor:pointer}
    .pw-btn-submit:hover{filter:brightness(1.07);transform:translateY(-1px)}
    .pw-error{color:#dc2626;font-size:.8rem;font-family:'DM Sans',sans-serif;margin-top:.3rem}
    .pw-val-summary{background:#fef2f2;border:1.5px solid #fca5a5;border-radius:var(--radius-sm);padding:.75rem 1rem;font-family:'DM Sans',sans-serif;font-size:.875rem;color:#dc2626;margin-bottom:1.5rem}

    .pw-section-title{font-family:'Fraunces',serif;font-size:1.05rem;font-weight:700;color:var(--text-main);margin-bottom:1.2rem;padding-bottom:.6rem;border-bottom:2px solid var(--green-100);display:flex;align-items:center;gap:.5rem}
    .pw-section-title i{color:var(--green-700)}
</style>

<div class="pw-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-7 col-lg-9">

                <div class="pw-header">
                    <h1 class="pw-title">Створення Адміна</h1>
                    <a href="/SuperAdmin/Admins" class="pw-btn-back">
                        <i class="bi bi-arrow-left"></i> Назад
                    </a>
                </div>

                <div class="pw-card">
                    <form method="post" asp-action="CreateAdmin">

                        <div class="pw-form-body">
                            
                            <div class="pw-section-title">
                                <i class="bi bi-person-fill"></i> Дані користувача
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-sm-6">
                                    <label class="pw-label">Ім'я</label>
                                    <input asp-for="FirstName" class="pw-input" placeholder="Введіть ім'я" />
                                    <span asp-validation-for="FirstName" class="pw-error"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="pw-label">Прізвище</label>
                                    <input asp-for="LastName" class="pw-input" placeholder="Введіть прізвище" />
                                    <span asp-validation-for="LastName" class="pw-error"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="pw-label">Email</label>
                                <input asp-for="Email" class="pw-input" placeholder="example@gmail.com" />
                                <span asp-validation-for="Email" class="pw-error"></span>
                            </div>

                            <div class="mb-1">
                                <label class="pw-label">Пароль</label>
                                <input type="password" name="password" class="pw-input" placeholder="Введіть пароль" />
                            </div>

                        </div>

                        <div class="pw-form-footer">
                            <button type="submit" class="pw-btn-submit">
                                <i class="bi bi-person-plus-fill"></i> Створити адміна
                            </button>
                            <a href="/SuperAdmin/Admins" class="pw-btn-back">Скасувати</a>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>
</div>
