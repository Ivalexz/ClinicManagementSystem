@model ApplicationUser

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Редагування користувача</h2>

    <a href="/SuperAdmin" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <form method="post" asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Ім'я</label>
                <input asp-for="FirstName" class="form-control" placeholder="Введіть ім'я" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Прізвище</label>
                <input asp-for="LastName" class="form-control" placeholder="Введіть прізвище" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input asp-for="Email" class="form-control" placeholder="example@gmail.com" />
            </div>

            <div class="mt-4">
                <button class="btn btn-warning">
                    <i class="bi bi-save"></i> Зберегти
                </button>
            </div>

        </form>

    </div>
</div>