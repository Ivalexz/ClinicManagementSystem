@model ClinicManagementSystem.Models.ViewModels.CreateDoctorViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Створення Доктора</h2>

    <a href="/SuperAdmin/Doctors" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <form method="post" asp-action="CreateDoctor">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            
            <h4 class="fw-bold mb-3">
                <i class="bi bi-person-fill"></i> Дані користувача
            </h4>

            <div class="mb-3">
                <label class="form-label fw-semibold">Ім'я</label>
                <input asp-for="User.FirstName" class="form-control" placeholder="Введіть ім'я" />
                <span asp-validation-for="User.FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Прізвище</label>
                <input asp-for="User.LastName" class="form-control" placeholder="Введіть прізвище" />
                <span asp-validation-for="User.LastName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input asp-for="User.Email" class="form-control" placeholder="example@gmail.com" />
                <span asp-validation-for="User.Email" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Пароль</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Введіть пароль" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <hr class="my-4" />


            <h4 class="fw-bold mb-3">
                <i class="bi bi-hospital"></i> Профіль доктора
            </h4>

            <div class="mb-3">
                <label class="form-label fw-semibold">Спеціалізація</label>
                <input asp-for="Doctor.Specialization" class="form-control" placeholder="Наприклад: Хірург" />
                <span asp-validation-for="Doctor.Specialization" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Документ освіти</label>
                <input asp-for="Doctor.EducationDocument" class="form-control" placeholder="Назва документа" />
                <span asp-validation-for="Doctor.EducationDocument" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Стаж роботи (роки)</label>
                <input asp-for="Doctor.ExperienceYears" class="form-control" placeholder="Наприклад: 5" />
                <span asp-validation-for="Doctor.ExperienceYears" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Номер кабінету</label>
                <input asp-for="Doctor.OfficeNumber" class="form-control" placeholder="Наприклад: 203" />
                <span asp-validation-for="Doctor.OfficeNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Телефон</label>
                <input asp-for="Doctor.Phone" class="form-control" placeholder="+380..." />
                <span asp-validation-for="Doctor.Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Опис / Біографія</label>
                <textarea asp-for="Doctor.Description" class="form-control" rows="4" placeholder="Коротка інформація про лікаря"></textarea>
                <span asp-validation-for="Doctor.Description" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button class="btn btn-success">
                    <i class="bi bi-person-check-fill"></i> Створити
                </button>
            </div>

        </form>

    </div>
</div>