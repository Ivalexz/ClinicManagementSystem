<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicMS</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        .navbar-premium {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            padding: 14px 0;
        }

        .navbar-premium .nav-link {
            color: #ffffff !important;
            font-weight: 500;
            transition: 0.2s ease;
        }

        .navbar-premium .nav-link:hover {
            color: #dfe9ff !important;
            transform: translateY(-2px);
        }

        .navbar-premium .btn-light:hover {
            background: #f8f9fa;
            transform: translateY(-2px);
        }

        footer {
            background: #0d6efd;
            color: white;
            padding: 20px 0;
            margin-top: 40px;
        }
    </style>
</head>

<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-premium shadow-sm">
        <div class="container">

            <a class="navbar-brand text-white fw-bold fs-4" href="/">
                <i class="bi bi-hospital-fill"></i> ClinicMS
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto gap-2">

                    <!-- Головна -->
                    <li class="nav-item">
                        <a class="nav-link" href="/">Головна</a>
                    </li>

                    <!-- ADMIN MENU -->
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin">
                                <i class="bi bi-speedometer2"></i> Адмін панель
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Patients">
                                <i class="bi bi-people"></i> Пацієнти
                            </a>
                        </li>
                    }

                    <!-- SUPERADMIN MENU -->
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/SuperAdmin">
                                <i class="bi bi-shield-lock-fill"></i> Super Admin
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/SuperAdmin/Admins">
                                <i class="bi bi-person-badge-fill"></i> Адміни
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/SuperAdmin/Doctors">
                                <i class="bi bi-heart-pulse-fill"></i> Доктори
                            </a>
                        </li>
                    }

                    <!-- AUTH USER -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-bold" href="/Account/Profile">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                        </li>

                        <li class="nav-item">
                            <form method="post" action="/Account/Logout">
                                <button class="btn btn-light px-3">Вийти</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-light px-3" href="/Account/Login">Увійти</a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>
</header>

<main class="container py-4">
    @RenderBody()
</main>

<footer class="text-center">
    © @DateTime.Now.Year Clinic Management System
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
