<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - PawCare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/ClinicManagementSystem.styles.css" asp-append-version="true"/>
</head>
<body>

<header class="site-header sticky-top">
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                <div class="logo-icon"><i class="bi bi-heart-pulse-fill"></i></div>
                <div>
                    <div class="logo-name">PawCare</div>
                    <div class="logo-sub">Vet Clinic</div>
                </div>
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Головна</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Services" asp-action="Index">Послуги</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Політика конфіденційності</a>
                    </li>
                </ul>
                @if (!User.Identity!.IsAuthenticated)
                {
                    <a class="btn btn-book ms-lg-3" asp-area="" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Вхід персоналу
                    </a>
                }
                else
                {
                    <div class="dropdown ms-lg-3">
                        <button class="btn btn-book dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-2"></i>@User.Identity.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-2"></i>Кабінет</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right me-2"></i>Вихід
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </nav>
</header>

<main role="main">
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="container">
        <div class="row g-4 pb-4 footer-top">
            <div class="col-lg-4">
                <a class="navbar-brand d-flex align-items-center gap-2 mb-3" href="#">
                    <div class="logo-icon"><i class="bi bi-heart-pulse-fill"></i></div>
                    <div>
                        <div class="logo-name text-white">PawCare</div>
                        <div class="logo-sub footer-logo-sub">Vet Clinic</div>
                    </div>
                </a>
                <p class="footer-desc">Ми дбаємо про здоров'я вашого вихованця так само, як ви. Сучасна клініка з людяним підходом.</p>
            </div>
            <div class="col-6 col-lg-3">
                <h6 class="footer-heading">Контакти</h6>
                <ul class="list-unstyled footer-links">
                    <li><a href="#">вул. Любомира Гузара 49</a></li>
                    <li><a href="tel:+380991234567">+38 (099) 123-45-67</a></li>
                    <li><a href="#">Пн–Нд: 8:00–21:00</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 pt-3">
            <span>&copy; 2026 PawCare. Всі права захищені.</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Політика конфіденційності</a>
        </div>
    </div>
</footer>

<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
