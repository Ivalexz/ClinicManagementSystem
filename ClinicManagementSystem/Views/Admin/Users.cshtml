@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Користувачі";
}

<h2 class="mb-4">Список користувачів</h2>

<a href="/Admin/CreateUser" class="btn btn-primary mb-3">➕ Створити користувача</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
    <tr>
        <th>Ім'я</th>
        <th>Прізвище</th>
        <th>Email</th>
        <th>Дії</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.FirstName</td>
            <td>@user.LastName</td>
            <td>@user.Email</td>
            <td>
                <a href="/Admin/EditUser/@user.Id" class="btn btn-warning btn-sm">✏ Редагувати</a>
                <a href="/Admin/DeleteUser/@user.Id" class="btn btn-danger btn-sm"
                   onclick="return confirm('Видалити користувача?')">🗑 Видалити</a>
                <a href="/Admin/Animals?userId=@user.Id" class="btn btn-info btn-sm">🐾 Тварини</a>
            </td>
        </tr>
    }
    </tbody>
</table>