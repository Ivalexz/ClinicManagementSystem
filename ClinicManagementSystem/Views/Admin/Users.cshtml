@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Користувачі";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Список користувачів</h2>

    <a href="/Admin/CreateUser" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Створити користувача
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover table-striped mb-0">
            <thead class="table-primary">
            <tr>
                <th>Ім'я</th>
                <th>Прізвище</th>
                <th>Email</th>
                <th class="text-center">Дії</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FirstName</td>
                    <td>@user.LastName</td>
                    <td>@user.Email</td>

                    <td class="text-center">

                        <a href="/Admin/EditUser/@user.Id" 
                           class="btn btn-outline-warning btn-sm me-1">
                            <i class="bi bi-pencil-square"></i> Редагувати
                        </a>

                        <a href="/Admin/DeleteUser/@user.Id"
                           class="btn btn-outline-danger btn-sm me-1"
                           onclick="return confirm('Видалити користувача?')">
                            <i class="bi bi-trash"></i> Видалити
                        </a>

                        <a href="/Admin/Animals?userId=@user.Id"
                           class="btn btn-outline-info btn-sm">
                            <i class="bi bi-paw"></i> Тварини
                        </a>

                    </td>
                </tr>
            }
            </tbody>
        </table>

    </div>
</div>