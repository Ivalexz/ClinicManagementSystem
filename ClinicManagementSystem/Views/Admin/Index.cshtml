            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">Тварини</h5>
                <p class="card-text">Управління тваринами та медкартами</p>
                <a href="/Admin/CreateAnimal" class="btn btn-success w-100 mb-2">➕ Додати тварину</a>
                <a href="/Admin/Animals" class="btn btn-outline-success w-100">🐾 Список тварин</a>
