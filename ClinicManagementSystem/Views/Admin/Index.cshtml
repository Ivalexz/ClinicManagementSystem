@{
    ViewData["Title"] = "Адмін панель";
}

<div class="d-flex justify-content-center mb-4">
    <h2 class="fw-bold text-center">Адмін панель</h2>
</div>

<div class="row g-4 justify-content-center">

    <!-- Користувачі -->
    <div class="col-md-6 col-lg-4 d-flex justify-content-center">
        <div class="card admin-card shadow-lg border-0">
            <div class="card-body d-flex flex-column">

                <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3">
                    <i class="bi bi-people-fill"></i>
                </div>

                <h5 class="card-title fw-bold mb-2">Користувачі</h5>

                <p class="text-muted flex-grow-1">
                    Управління власниками тварин
                </p>

                <a href="/Admin/CreateUser" class="btn btn-primary w-100 mb-2">
                    <i class="bi bi-person-plus"></i> Створити користувача
                </a>

                <a href="/Admin/Users" class="btn btn-outline-primary w-100">
                    <i class="bi bi-card-list"></i> Список користувачів
                </a>

            </div>
        </div>
    </div>

    <!-- Тварини -->
    <div class="col-md-6 col-lg-4 d-flex justify-content-center">
        <div class="card admin-card shadow-lg border-0">
            <div class="card-body d-flex flex-column">

                <div class="icon-circle bg-success bg-opacity-10 text-success mb-3">
                    <i class="bi bi-paw-fill"></i>
                </div>

                <h5 class="card-title fw-bold mb-2">Тварини</h5>

                <p class="text-muted flex-grow-1">
                    Управління тваринами та медкартами
                </p>

                <a href="/Admin/CreateAnimal" class="btn btn-success w-100 mb-2">
                    <i class="bi bi-plus-circle"></i> Додати тварину
                </a>

                <a href="/Admin/Animals" class="btn btn-outline-success w-100">
                    <i class="bi bi-list-ul"></i> Список тварин
                </a>

            </div>
        </div>
    </div>

</div>

<style>
    .admin-card {
        width: 100%;
        max-width: 360px;
        min-height: 330px;
        border-radius: 18px;
        padding: 6px;
        background: linear-gradient(145deg, #ffffff, #f3f6ff);
        transition: transform .25s ease, box-shadow .25s ease;
    }

    .admin-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 18px 40px rgba(0,0,0,0.15);
    }

    .icon-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 12px;
    }

    h2 {
        font-size: 2rem;
        letter-spacing: 0.5px;
    }
</style>
