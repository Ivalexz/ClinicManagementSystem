@using ClinicManagementSystem.ViewModels
@model CreateUserViewModel

@{
    ViewData["Title"] = "Створення користувача";
}

<div class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">

                <div class="auth-card">
                    <div class="auth-logo mb-4">
                        <div class="logo-icon mx-auto mb-3">
                            <i class="bi bi-person-plus-fill"></i>
                        </div>
                        <h1 class="auth-title">Створити користувача</h1>
                        <p class="auth-sub">Додайте нового користувача до системи</p>
                        <div asp-validation-summary="All"></div>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="auth-alert mb-3">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <form method="post" asp-action="CreateUser">

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Ім'я</label>
                                <div class="input-icon-wrap">
                                    <i class="bi bi-person input-icon"></i>
                                    <input asp-for="FirstName" class="form-control ps-input-icon"
                                           placeholder="Ім'я" required autocomplete="given-name" />
                                </div>
                                <span asp-validation-for="FirstName" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-6 mb-3">
                                <label class="form-label">Прізвище</label>
                                <div class="input-icon-wrap">
                                    <i class="bi bi-person input-icon"></i>
                                    <input asp-for="LastName" class="form-control ps-input-icon"
                                           placeholder="Прізвище" required autocomplete="family-name" />
                                </div>
                                <span asp-validation-for="LastName" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-envelope input-icon"></i>
                                <input asp-for="Email" class="form-control ps-input-icon"
                                       placeholder="example@gmail.com" required autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Пароль</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock input-icon"></i>
                                <input asp-for="Password" id="password"
                                       class="form-control ps-input-icon"
                                       placeholder="••••••••"
                                       required autocomplete="new-password" />
                            </div>
                            <div class="password-hint mt-1">
                                Мінімум 6 символів, велика літера та цифра
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">Підтвердження пароля</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock-fill input-icon"></i>
                                <input asp-for="ConfirmPassword" type="password"
                                       class="form-control ps-input-icon"
                                       placeholder="••••••••"
                                       required autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                        </div>

                        <button type="submit" class="btn-submit">
                            <i class="bi bi-check-circle me-2"></i>Створити користувача
                        </button>
                    </form>

                    <p class="auth-footer-text mt-4">
                        <a href="/Admin/Users" class="auth-link">
                            <i class="bi bi-arrow-left me-1"></i>Назад до списку користувачів
                        </a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const firstName = document.querySelector('input[name="FirstName"]');
        const lastName = document.querySelector('input[name="LastName"]');
        const email = document.querySelector('input[name="Email"]');
        const pwd = document.getElementById('password');
        const btn = document.querySelector('.btn-submit');

        function validateForm() {
            const isNameValid = firstName.value.trim().length > 0 && lastName.value.trim().length > 0;
            const isEmailValid = email.value.trim().length > 0 && /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email.value);
            const isPwdValid = pwd.value.length >= 6;

            btn.disabled = !(isNameValid && isEmailValid && isPwdValid);
        }

        firstName.addEventListener('input', validateForm);
        lastName.addEventListener('input', validateForm);
        email.addEventListener('input', validateForm);
        pwd.addEventListener('input', validateForm);

        validateForm();
    </script>
}
