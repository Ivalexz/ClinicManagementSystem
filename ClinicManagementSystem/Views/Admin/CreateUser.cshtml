@model ApplicationUser

@{
    ViewData["Title"] = "Створення користувача";
}

<h2 class="mb-4">Створення користувача</h2>

<form method="post" asp-action="CreateUser">
    <div class="mb-3">
        <label class="form-label">Ім'я</label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Прізвище</label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Пароль</label>
        <input type="password" name="password" class="form-control" />
    </div>

    <button class="btn btn-success">Створити</button>
    <a href="/Admin/Users" class="btn btn-secondary">Назад</a>
</form>